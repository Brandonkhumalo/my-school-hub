# ============================================================
# MySchoolHub — Backend .env.example
# Copy to .env and fill in real values.
# NEVER commit your .env to version control.
# ============================================================

# ---------------------------------------------------------------
# Core Django
# ---------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=generate-a-secure-key-here

# Set to False in production
DEBUG=False

# '*' works on Railway (Railway validates the domain at their edge).
# For stricter control: your-app.up.railway.app,myschoolhub.co.zw
ALLOWED_HOSTS=*

# ---------------------------------------------------------------
# CORS — your frontend domain(s), comma-separated
# ---------------------------------------------------------------
CORS_ALLOWED_ORIGINS=https://myschoolhub.co.zw,https://www.myschoolhub.co.zw

# ---------------------------------------------------------------
# Database (Railway PostgreSQL plugin)
# Railway auto-sets DATABASE_URL when you add the Postgres plugin.
# Copy the value from: Railway dashboard → Postgres → Connect → DATABASE_URL
# ---------------------------------------------------------------
DATABASE_URL=postgresql://user:password@host:5432/railway

# ---------------------------------------------------------------
# Redis (optional — Railway Redis plugin)
# If not set, the app uses in-memory cache and DB-backed sessions.
# Add the Railway Redis plugin and copy its REDIS_URL variable.
# ---------------------------------------------------------------
REDIS_URL=
CELERY_BROKER_URL=

# ---------------------------------------------------------------
# Resend Email (https://resend.com)
# ---------------------------------------------------------------
ResendEmailApiKey=re_your_api_key_here
ResendFromEmail=noreply@myschoolhub.co.zw
Destination=info@myschoolhub.co.zw

# ---------------------------------------------------------------
# Superadmin secret (protects /api/v1/auth/superadmin/register/)
# ---------------------------------------------------------------
SUPERADMIN_SECRET_KEY=generate-a-different-secure-key-here

# ---------------------------------------------------------------
# PayNow Zimbabwe (set per-school in Admin → School Settings)
# These two URLs must be public and point to your Railway domain:
# ---------------------------------------------------------------
PAYNOW_RETURN_URL=https://myschoolhub.co.zw/payment/success
PAYNOW_RESULT_URL=https://your-app.up.railway.app/api/v1/finances/payments/paynow/result/

# ---------------------------------------------------------------
# WhatsApp Business API (Meta)
# ---------------------------------------------------------------
WHATSAPP_API_URL=https://graph.facebook.com/v18.0/YOUR_PHONE_NUMBER_ID
WHATSAPP_ACCESS_TOKEN=your-permanent-access-token
WHATSAPP_VERIFY_TOKEN=your-custom-verify-token
WHATSAPP_APP_SECRET=your-app-secret
