# ============================================================
# MySchoolHub — Backend .env.example
# Copy to .env and fill in real values.
# NEVER commit your .env to version control.
# ============================================================

# ---------------------------------------------------------------
# Core Django
# ---------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=generate-a-secure-key-here

# Set to False in production
DEBUG=False

# Comma-separated: your domain, Elastic IP, and localhost (localhost needed for Docker health checks)
ALLOWED_HOSTS=myschoolhub.co.zw,www.myschoolhub.co.zw,<YOUR_ELASTIC_IP>,localhost

# ---------------------------------------------------------------
# CORS — your frontend domain(s), comma-separated
# ---------------------------------------------------------------
CORS_ALLOWED_ORIGINS=https://myschoolhub.co.zw,https://www.myschoolhub.co.zw

# CSRF trusted origins — same as CORS origins (required behind ALB)
CSRF_TRUSTED_ORIGINS=https://myschoolhub.co.zw,https://www.myschoolhub.co.zw

# ---------------------------------------------------------------
# Database (RDS PostgreSQL)
# Format: postgresql://USER:PASSWORD@HOST:5432/DBNAME
# ---------------------------------------------------------------
DATABASE_URL=postgresql://schoolhub_svc:your-password@schoolhub-db.xxxxx.af-south-1.rds.amazonaws.com:5432/schoolhub

# ---------------------------------------------------------------
# Redis (ElastiCache)
# Format: redis://HOST:6379/0
# If not set, the app uses in-memory cache (fine for Phase 1).
# ---------------------------------------------------------------
REDIS_URL=redis://schoolhub-redis.xxxxx.af-south-1.cache.amazonaws.com:6379/0
CELERY_BROKER_URL=redis://schoolhub-redis.xxxxx.af-south-1.cache.amazonaws.com:6379/0

# ---------------------------------------------------------------
# AWS S3 — Media file storage (optional)
# Leave AWS_STORAGE_BUCKET_NAME empty to use local filesystem.
# When set, uploaded files go to S3 instead of ephemeral disk.
# IAM role on EC2 provides credentials — no keys needed.
# ---------------------------------------------------------------
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=af-south-1

# ---------------------------------------------------------------
# AWS ECR — Docker image registry
# ---------------------------------------------------------------
ECR_REGISTRY=123456789.dkr.ecr.af-south-1.amazonaws.com

# ---------------------------------------------------------------
# Resend Email (https://resend.com)
# ---------------------------------------------------------------
ResendEmailApiKey=re_your_api_key_here
ResendFromEmail=noreply@myschoolhub.co.zw
Destination=info@myschoolhub.co.zw

# ---------------------------------------------------------------
# Superadmin secret (protects /api/v1/auth/superadmin/register/)
# ---------------------------------------------------------------
SUPERADMIN_SECRET_KEY=generate-a-different-secure-key-here

# ---------------------------------------------------------------
# PayNow Zimbabwe (set per-school in Admin → School Settings)
# These URLs must be public and point to your domain:
# ---------------------------------------------------------------
PAYNOW_RETURN_URL=https://myschoolhub.co.zw/payment/success
PAYNOW_RESULT_URL=https://api.myschoolhub.co.zw/api/v1/finances/payments/paynow/result/

# ---------------------------------------------------------------
# WhatsApp Business API (Meta)
# ---------------------------------------------------------------
WHATSAPP_API_URL=https://graph.facebook.com/v18.0/YOUR_PHONE_NUMBER_ID
WHATSAPP_ACCESS_TOKEN=your-permanent-access-token
WHATSAPP_VERIFY_TOKEN=your-custom-verify-token
WHATSAPP_APP_SECRET=your-app-secret

# ---------------------------------------------------------------
# Gunicorn — worker configuration
# ---------------------------------------------------------------
WEB_CONCURRENCY=4
