# Environment variables — never commit secrets
.env
*.env
# Allow the production env file (only contains the public AWS URL, no secrets)
!.env.production

# Logs — keep the directory, ignore log files
School_system/logs/*.log
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Django migrations (auto-generated, not tracked)
*/migrations/*.py
!*/migrations/__init__.py

# Django runtime files
db.sqlite3
*.sqlite3
/School_system/staticfiles/
/School_system/media/

# Claude memory
.claude/

.venv/